# Copy to .env and fill in. Do not commit .env.
#
# Weights & Biases — paste your API key from https://wandb.ai/authorize
# Loaded automatically when you run `uv run python text_cond_train.py` (omit --no-wandb to sync)
# If unset, run `wandb login` once; it stores credentials in ~/.netrc
# For cloud runs, do not set WANDB_MODE=disabled
WANDB_API_KEY=
# Default project in the W&B UI (overrides the code default csci1430-tc-ijepa)
WANDB_PROJECT=csci1430-tc-ijepa
